<div class="terminal">
    <div class="scan-line"></div>

    <div class="protocol-grid">
        <div class="user-panel">
            <div class="user-label">// идентификация</div>
            <div class="user-name">
                USER: <span>UNKNOWN</span>
            </div>
        </div>
        <div class="metric-panel">
            <div class="last-hope-text">LAST HOPE</div>
        </div>
    </div>

    <!-- Блок протокола: кнопка сканирования + динамические зоны -->
    <div class="protocol-status" id="protocolStatus">
        <div class="scan-row">
            <button class="scan-button" id="scanBtn">[Сканировать]</button>
        </div>
        <!-- Зона для анимированной линии загрузки -->
        <div class="progress-area" id="progressArea">
            <div class="progress-label">⟳ АНАЛИЗ СИСТЕМЫ ⟳</div>
            <div class="progress-bar-bg">
                <div class="progress-fill" id="progressFill"></div>
            </div>
        </div>
        <!-- Зона для кнопки "протокол Gamma" -->
        <div class="gamma-area" id="gammaArea">
            <button class="gamma-button" id="gammaBtn">[протокол "Gamma"]</button>
        </div>
    </div>

    <div class="footer-status">
        <div class="sys-badge">
            ⚙️ SR-A
        </div>
        <div class="info-tag">
            <span>PROTOCOL: v.82.0_alpha</span>
            <span>ENCRYPT: ACTIVE</span>
            <span id="uptimeDisplay">UPTIME: 00:00:00</span>
        </div>
    </div>

    <div class="hud-corner">
        [ SECURE TERMINAL | SYS_ID: SR-A | LAST HOPE ]
    </div>
</div>

<script>
    (function() {
        // Элементы
        const scanBtn = document.getElementById('scanBtn');
        const progressArea = document.getElementById('progressArea');
        const progressFill = document.getElementById('progressFill');
        const gammaArea = document.getElementById('gammaArea');
        const gammaBtn = document.getElementById('gammaBtn');
        const protocolStatus = document.getElementById('protocolStatus');
        const lastHopeElement = document.querySelector('.last-hope-text');

        let scanning = false;
        let animationFrame = null;
        let startTime = 0;
        let animDuration = 2000; // 2 секунды

        // Функция сброса состояния (убираем гамму, прячем прогресс, останавливаем анимацию)
        function resetScanState(resetButton = true) {
            if (animationFrame) {
                cancelAnimationFrame(animationFrame);
                animationFrame = null;
            }
            scanning = false;
            // Скрываем прогресс-зону и гамма-зону
            progressArea.style.display = 'none';
            gammaArea.style.display = 'none';
            // Сбрасываем ширину заполнения
            progressFill.style.width = '0%';
            if (resetButton) {
                scanBtn.disabled = false;
                scanBtn.textContent = '[Сканировать]';
            }
        }

        // Функция для плавной анимации прогресса
        function startProgressAnimation() {
            return new Promise((resolve) => {
                startTime = performance.now();
                progressFill.style.width = '0%';
                
                function update(currentTime) {
                    const elapsed = currentTime - startTime;
                    let percent = Math.min(1, elapsed / animDuration);
                    const widthPercent = percent * 100;
                    progressFill.style.width = `${widthPercent}%`;
                    
                    if (percent < 1) {
                        animationFrame = requestAnimationFrame(update);
                    } else {
                        // Анимация завершена
                        animationFrame = null;
                        resolve();
                    }
                }
                animationFrame = requestAnimationFrame(update);
            });
        }

        // Обработчик клика по кнопке Сканировать
        async function onScanClick() {
            if (scanning) return; // уже сканируем
            
            // Сбрасываем предыдущее состояние (если есть гамма или незавершённое сканирование)
            resetScanState(true);
            
            // Запускаем сканирование
            scanning = true;
            scanBtn.disabled = true;
            scanBtn.textContent = '[СКАНИРОВАНИЕ...]';
            
            // Показываем зону прогресса
            progressArea.style.display = 'flex';
            gammaArea.style.display = 'none';
            
            // Небольшая задержка для плавности появления
            await new Promise(r => setTimeout(r, 30));
            
            // Запускаем анимацию заполнения
            await startProgressAnimation();
            
            // Анимация завершена: скрываем прогресс-бар
            progressArea.style.display = 'none';
            
            // Показываем кнопку Gamma (окошко удлиняется автоматически)
            gammaArea.style.display = 'flex';
            
            // Визуальный эффект: лёгкое свечение блока
            protocolStatus.style.borderColor = '#ff66aa';
            protocolStatus.style.boxShadow = '0 0 12px rgba(255, 102, 170, 0.3)';
            setTimeout(() => {
                protocolStatus.style.borderColor = '';
                protocolStatus.style.boxShadow = '';
            }, 600);
            
            // Эффект на надпись LAST HOPE (вспышка)
            if (lastHopeElement) {
                lastHopeElement.style.textShadow = '0 0 25px #ff6699, 0 0 45px #ff3366';
                setTimeout(() => {
                    lastHopeElement.style.textShadow = '';
                }, 400);
            }
            
            // Завершаем сканирование, кнопка снова активна, но теперь можно повторно запустить (сбросив Gamma)
            scanning = false;
            scanBtn.disabled = false;
            scanBtn.textContent = '[Сканировать]';
            
            // Лог в консоль
            console.log(`[СКАНИРОВАНИЕ ЗАВЕРШЕНО] ${new Date().toLocaleTimeString()} — Протокол Gamma готов`);
        }
        
        // Обработчик для кнопки Gamma (можно добавить дополнительное действие)
        if (gammaBtn) {
            gammaBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                console.log(`[ПРОТОКОЛ GAMMA] Активирован в ${new Date().toLocaleTimeString()}`);
                // Визуальный фидбек: мигание заголовка LAST HOPE
                if (lastHopeElement) {
                    lastHopeElement.style.animation = 'none';
                    lastHopeElement.style.textShadow = '0 0 35px #ff00aa, 0 0 60px #ff3366';
                    setTimeout(() => {
                        lastHopeElement.style.animation = 'pulseRedGlow 1.8s infinite alternate';
                        lastHopeElement.style.textShadow = '';
                    }, 500);
                }
                // Дополнительный эффект на блок протокола
                protocolStatus.style.borderColor = '#ffccff';
                protocolStatus.style.transition = '0.2s';
                setTimeout(() => {
                    protocolStatus.style.borderColor = '';
                }, 400);
                // Можно вывести сообщение в консоль, но не блокируем интерфейс
            });
        }
        
        // Привязываем событие к кнопке сканирования
        if (scanBtn) {
            scanBtn.addEventListener('click', onScanClick);
        }
        
        // Счётчик Uptime
        const startTimeUptime = Date.now();
        const uptimeElement = document.getElementById('uptimeDisplay');
        
        function updateUptime() {
            if (!uptimeElement) return;
            const elapsed = Math.floor((Date.now() - startTimeUptime) / 1000);
            const hours = Math.floor(elapsed / 3600);
            const minutes = Math.floor((elapsed % 3600) / 60);
            const seconds = elapsed % 60;
            uptimeElement.textContent = `UPTIME: ${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
        }
        updateUptime();
        setInterval(updateUptime, 1000);
        
        // Динамический заголовок
        const originalTitle = "SR-A // LAST HOPE";
        document.title = originalTitle;
        setInterval(() => {
            if (Math.random() > 0.88) {
                document.title = "> " + originalTitle + " _";
                setTimeout(() => { document.title = originalTitle; }, 400);
            }
        }, 4000);
        
        console.log("%c[SR-A] СИСТЕМА АКТИВНА // LAST HOPE", "color: #ff3366; font-family: monospace; font-size: 12px");
        console.log("%c[USER: UNKNOWN]  |  SR-A ONLINE // LAST HOPE", "color: #6fcf97; font-family: monospace;");
        console.log("%c[ИНСТРУКЦИЯ] Нажмите [Сканировать] — запустится анимация линии, затем появится кнопка [протокол \"Gamma\"]", "color: #88ffaa");
    })();
</script>
</body>
</html>
